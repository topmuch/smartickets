# SmarticketS Environment Configuration
# Copy this file to .env and fill in your values

# Database (SQLite - file path)
DATABASE_URL=file:/app/data/custom.db

# Base URL for your application
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# NextAuth Secret (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# PayPal Configuration
# Get your credentials from: https://developer.paypal.com/developer/applications/
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Encryption Key (generate a secure 32+ character string)
# You can use: openssl rand -base64 32
ENCRYPTION_KEY=your-secure-encryption-key-here

# Optional: SMTP Email Configuration
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=noreply@smartickets.com

# ─── WAKIT (WhatsApp Business API) ───
WAKIT_API_KEY=
WAKIT_BASE_URL=https://api.wakit.ai/v1
WAKIT_PHONE_NUMBER_ID=
WAKIT_TEMPLATE_SCAN_ALERT=baggage_scan_alert
WAKIT_TIMEOUT_MS=10000

# ─── GROQ (AI Inference) ───
GROQ_API_KEY=
GROQ_MODEL_CHAT=llama3-8b-8192
GROQ_MODEL_ANALYSIS=llama3-8b-8192
GROQ_TIMEOUT_MS=30000

# ─── GROQ AI — Master kill switch ───
# Set to 'false' to disable ALL AI features (overrides DB flags)
GROQ_AI_ENABLED=true

# ─── AI Feature Kill Switches ───
# Priority: env var > DB FeatureFlag (admin dashboard)
GROQ_CHAT_ENABLED=true           # Chatbot Trouveur
GROQ_SCAN_GUARD_ENABLED=true    # Analyse Anti-Doublon
GROQ_AUTO_TRANSLATE_ENABLED=true # Traduction Auto
