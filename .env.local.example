# ═══════════════════════════════════════════════════════
# SmarticketS — Variables d'environnement
# ═══════════════════════════════════════════════════════
# Copier ce fichier en .env.local et remplir les valeurs.
# Ne JAMAIS commiter .env.local (déjà dans .gitignore).
# ═══════════════════════════════════════════════════════

# ─── Base de données ───
DATABASE_URL=file:./db/qrtrans.db

# ─── WAKIT (WhatsApp Business API) ───
# Documentation: https://docs.wakit.ai
WAKIT_API_KEY=
WAKIT_BASE_URL=https://api.wakit.ai/v1
WAKIT_PHONE_NUMBER_ID=
WAKIT_TEMPLATE_SCAN_ALERT=baggage_scan_alert
# Timeout en ms pour les appels Wakit
WAKIT_TIMEOUT_MS=10000

# ─── GROQ (AI Inference) ───
# Documentation: https://console.groq.com/docs
GROQ_API_KEY=
GROQ_MODEL_CHAT=llama3-8b-8192
GROQ_MODEL_ANALYSIS=llama3-8b-8192
# Timeout en ms pour les appels Groq
GROQ_TIMEOUT_MS=30000

# ─── GROQ AI — Master kill switch ───
# Passer à 'false' pour désactiver TOUTE l'IA (priorité sur les flags DB)
GROQ_AI_ENABLED=true

# ─── AI-FEATURE: Kill switches individuels ───
# Priorité: env var > DB FeatureFlag (admin dashboard)
GROQ_CHAT_ENABLED=true           # Feature #1: Chatbot Trouveur
GROQ_SCAN_GUARD_ENABLED=true    # Feature #2: Analyse Anti-Doublon
GROQ_AUTO_TRANSLATE_ENABLED=true # Feature #3: Traduction Auto
